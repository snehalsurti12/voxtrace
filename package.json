{
  "name": "audrique",
  "version": "0.2.0",
  "description": "End-to-end testing framework for contact centers. Coordinates voice call automation, CRM verification, and telephony validation in declarative test scenarios.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "contact-center",
    "e2e-testing",
    "salesforce",
    "service-cloud-voice",
    "amazon-connect",
    "playwright",
    "voice-testing",
    "ivr",
    "telephony",
    "twilio"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/audrique"
  },
  "bin": {
    "audrique": "./bin/audrique.mjs"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "instance:list": "node scripts/instance-profile.mjs list",
    "instance:current": "node scripts/instance-profile.mjs current",
    "instance:use": "node scripts/instance-profile.mjs use",
    "instance:auth:sf": "node scripts/run-instance.mjs auth:state",
    "instance:auth:provider": "node scripts/run-instance.mjs auth:provider-state",
    "instance:auth:connect": "node scripts/run-instance.mjs auth:connect-state",
    "instance:test:ui": "node scripts/run-instance.mjs test:ui",
    "instance:test:ui:state": "node scripts/run-instance.mjs test:ui:state",
    "instance:test:ui:state:video": "PW_VIDEO_MODE=on node scripts/run-instance.mjs test:ui:state",
    "instance:test:ui:state:video:merge": "PW_VIDEO_MODE=on node scripts/run-instance.mjs test:ui:state && npm run merge:videos",
    "instance:test:e2e": "node scripts/run-instance-e2e-suite.mjs",
    "instance:test:e2e:v2": "E2E_SUITE_FILE=scenarios/e2e/full-suite-v2.json node scripts/run-instance-e2e-suite.mjs",
    "instance:test:e2e:v2:dry": "E2E_SUITE_FILE=scenarios/e2e/full-suite-v2.json E2E_SUITE_DRY_RUN=true node scripts/run-instance-e2e-suite.mjs",
    "studio": "node webapp/server.mjs",
    "scenario:create": "node scripts/create-scenario.mjs",
    "scenario:create:append": "node scripts/create-scenario.mjs --append scenarios/e2e/full-suite-v2.json",
    "merge:videos": "node scripts/merge-e2e-videos.mjs",
    "highlight:reel": "node scripts/merge-e2e-highlight.mjs",
    "audio:sample": "node scripts/generate-fake-audio.mjs",
    "ivr:transcribe": "node scripts/ivr-transcriber.mjs",
    "auth:state": "node scripts/sf-login-probe.mjs",
    "auth:provider-state": "node scripts/capture-provider-session.mjs",
    "auth:connect-state": "node scripts/capture-connect-session.mjs",
    "refresh-auth": "node scripts/refresh-auth.mjs",
    "test:ui": "playwright test",
    "test:ui:state": "SF_SKIP_LOGIN=true playwright test",
    "typecheck": "tsc --noEmit",
    "test": "npm run typecheck && npm run test:ui"
  },
  "dependencies": {
    "ffmpeg-static": "^5.3.0",
    "twilio": "^5.8.0"
  },
  "optionalDependencies": {
    "@xenova/transformers": "^2.17.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.0",
    "@types/node": "^22.10.5",
    "typescript": "^5.7.2"
  }
}
