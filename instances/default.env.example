# Copy this file to instances/<your-instance>.env and fill values.
# Example:
#   cp instances/default.env.example instances/myorg.env
#   INSTANCE=myorg npm run instance:test:ui:state

# Security / secrets
# - env backend: *_REF points to environment variable name present at runtime
# - vault backend: *_REF points to "path/to/secret#field" (or "path/to/secret:field")
SECRETS_BACKEND=env
REGULATED_MODE=false

# Salesforce
SF_LOGIN_URL=https://test.salesforce.com
SF_USERNAME=
SF_USERNAME_REF=SF_USERNAME_SECRET
SF_PASSWORD=
SF_PASSWORD_REF=SF_PASSWORD_SECRET
SF_EMAIL_CODE=
SF_EMAIL_CODE_REF=
# Optional: can be blank if SF_INSTANCE_URL is set; runner will open home and switch by SF_APP_NAME.
SF_SERVICE_CONSOLE_URL=
# Preferred onboarding input: target app name (e.g. "Service Console").
SF_APP_NAME=Service Console
SF_INSTANCE_URL=https://your-org.sandbox.lightning.force.com
SF_APP_URL=
SF_STORAGE_STATE=.auth/sf-agent.json
SF_SKIP_LOGIN=true

# Voice test behavior
CALL_TRIGGER_MODE=manual
CALL_EXPECTATION=agent_offer
OMNI_TARGET_STATUS=Available
VOICE_RING_TIMEOUT_SEC=180
PROVIDER_SYNC_WAIT_SEC=20
PROVIDER_LOGIN_TIMEOUT_SEC=300
VERIFY_REALTIME_TRANSCRIPT=false
TRANSCRIPT_WAIT_SEC=60
TRANSCRIPT_EXPECT_PHRASE=
TRANSCRIPT_MIN_GROWTH_CHARS=12
TRANSCRIPT_REQUIRE_RIGHT_SIDE=true
VOICECALL_EXPECTED_OWNER=
VERIFY_SUPERVISOR_QUEUE_WAITING=false
VERIFY_SUPERVISOR_AGENT_OFFER=true
SUPERVISOR_APP_NAME=Supervisor Console
SUPERVISOR_SURFACE_NAME=
SUPERVISOR_QUEUE_NAME=
SUPERVISOR_AGENT_NAME=
SUPERVISOR_QUEUE_WAIT_TIMEOUT_SEC=180
SUPERVISOR_AGENT_OFFER_TIMEOUT_SEC=90
SUPERVISOR_POST_QUEUE_HOLD_SEC=2
OFFER_AFTER_QUEUE_TIMEOUT_SEC=180
SUPERVISOR_VIDEO_DIR=test-results/sf-supervisor-video
SUPERVISOR_AGENT_VIDEO_DIR=test-results/sf-supervisor-agent-video

# Connect (console -> CCP)
# Optional: set alias/host once and URL values will be derived automatically.
# Examples:
# CONNECT_INSTANCE_ALIAS=your-connect-instance-alias
# CONNECT_INSTANCE_ALIAS=your-connect-instance.my.connect.aws
CONNECT_INSTANCE_ALIAS=
AWS_USERNAME=
AWS_USERNAME_REF=
AWS_PASSWORD=
AWS_PASSWORD_REF=
AWS_ACCOUNT_ID=
AWS_ACCOUNT_ID_REF=
AWS_MFA_CODE=
# Connect Federation API (fast API auth, no browser console navigation)
# When all 3 are set, uses GetFederationToken API instead of browser flow.
# Requires: test user added as Connect user with connect:GetFederationToken IAM permission.
AWS_ACCESS_KEY_ID=
AWS_ACCESS_KEY_ID_REF=
AWS_SECRET_ACCESS_KEY=
AWS_SECRET_ACCESS_KEY_REF=
CONNECT_INSTANCE_ID=
CONNECT_INSTANCE_ID_REF=
CONNECT_CONSOLE_REGION=us-west-2
CONNECT_START_URL=
CONNECT_CCP_URL=
CONNECT_STORAGE_STATE=.auth/connect-ccp.json
CONNECT_LOGIN_TIMEOUT_SEC=900
CONNECT_AUTO_NAVIGATE_FROM_CONSOLE=false
CONNECT_AUTO_AWS_LOGIN=true
# Stability guard: prefer AWS Connect instances-table first-column link;
# only use emergency launch when explicitly enabled.
CONNECT_ALLOW_EMERGENCY_LAUNCH=false
CONNECT_DIAL_TIMEOUT_SEC=20000
CONNECT_CCP_IVR_DIGITS=
CONNECT_CCP_DTMF_MIN_CALL_ELAPSED_SEC=4
CONNECT_CCP_IVR_INITIAL_DELAY_MS=0
CONNECT_CCP_IVR_INTER_DIGIT_DELAY_MS=420
CONNECT_CCP_IVR_POST_DELAY_MS=1200

# Twilio (optional)
TWILIO_ACCOUNT_SID=
TWILIO_ACCOUNT_SID_REF=
TWILIO_AUTH_TOKEN=
TWILIO_AUTH_TOKEN_REF=
TWILIO_FROM_NUMBER=+14155550123
CONNECT_ENTRYPOINT_NUMBER=+18005550199
TWILIO_AUTO_HANGUP=true

# Vault runtime vars (only for SECRETS_BACKEND=vault; keep out of repo)
# VAULT_ADDR=https://vault.example.com
# VAULT_TOKEN=<runtime token>
